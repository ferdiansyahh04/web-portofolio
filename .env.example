# DataByte AI — API key (set di Vercel dashboard → Settings → Environment Variables)
# Dapatkan key di https://ai.databyte.co.id/dashboard → Keys
DATABYTE_API_KEY=sk-db-xxxxxxxxxxxxxxxxxxxx

# Optional — domain produksi kamu (kalau pake custom domain)
# Untuk *.vercel.app gak perlu di-set, sudah di-handle otomatis
# PUBLIC_SITE_URL=https://yourdomain.com
