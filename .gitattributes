# Normalize text files to LF in the repository
* text=auto eol=lf

# Keep common Windows scripts with CRLF when present
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common web source files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Treat binaries as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary